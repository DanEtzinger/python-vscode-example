    "10": {
      "title": "Example SQLite Rows",
      "type": "data",
      "query": "timeseries average = avg(`python_vscode.example.sqlite.rows`), by: {`dt.entity.sqlite:database`}\n| sort arrayAvg(average) desc\n| fieldsAdd name=entityName(`dt.entity.sqlite:database`)\n//| fieldsAdd name = coalesce(name, \"\")\n//| fieldsRemove `dt.entity.sqlite:database`\n| fields timeframe, interval, average, `dt.entity.sqlite:database`, name\n| limit 20",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "truncationMode": "middle",
          "leftYAxisSettings": {
            "label": "Example SQLite Rows",
            "isLabelVisible": true
