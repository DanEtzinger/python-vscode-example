    "9": {
      "title": "Summary - last value",
      "type": "data",
      "query": "timeseries {\n  metric1=avg(`python_vscode.example.sqlite.rows`)},\nby: {`dt.entity.sqlite:database`}\n| fieldsAdd entity_name = entityName(`dt.entity.sqlite:database`)\n| fieldsAdd entity_id = `dt.entity.sqlite:database`\n| fieldsAdd entity_url = concat(\"/ui/apps/dynatrace.classic.technologies/ui/entity/\", entity_id)\n| fieldsAdd entity = concat(\"[\", entity_name, \"]\", \"(\", entity_url, \")\")\n| fieldsAdd `SQLite Rows` = arrayLast(metric1)\n| sort entity_name asc\n| fields  entity,`SQLite Rows`\n| limit 20",
      "visualization": "table",
      "visualizationSettings": {
        "table": {
          "columnTypeOverrides": [
            {
              "id": 913702.4000000004,
              "fields": [
                "entity"
